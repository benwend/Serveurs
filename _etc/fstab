# /etc/fstab: static file system information.
#
# Use 'blkid' to print the universally unique identifier for a
# device; this may be used with UUID= as a more robust way to name devices
# that works even if disks are added and removed. See fstab(5).
#
# <file system> <mount point>   <type>  <options>       <dump>  <pass>
# / was on /dev/sda2 during installation
UUID=   /                   ext4    defaults,noatime,errors=remount-ro  0       1

# /boot was on /dev/sda1 during installation
UUID=   /boot               ext2    defaults,noatime    0       1

# /dev/mapper/HDD-* was on /dev/sdb6 during installation
/dev/mapper/HDD-Perso                       /home               ext4    defaults            0       2
/dev/mapper/HDD-Data                        /srv/data           btrfs   defaults            0       2
/dev/mapper/HDD-Virtualisation              /srv/virtualisation btrfs   defaults            0       2

# swap was on /dev/sdb5 during installation
UUID=   none                swap    sw                  0       0

# /tmp was on tmpfs after installation
tmpfs   /tmp                    tmpfs   defaults,size=5g  0   0

# /var/cache/... was on tmpfs after installation
tmpfs   /var/cache/apt/archives tmpfs   defaults,size=3g  0   0
